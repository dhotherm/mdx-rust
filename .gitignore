# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Keep Cargo.lock tracked for reproducible CLI builds.
examples/*/Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# mdx-rust specific
.mdx-rust/
**/.mdx-rust/
*.mdx-rustignore
.worktrees/
**/.worktrees/

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Environment & secrets
.env
.env.local
*.pem
secrets/
